# Server
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Groq: paste comma-separated keys here. Do not commit real keys.
# The backend also accepts GROQ_API_KEY1...GROQ_API_KEY10 aliases.
GROQ_API_KEYS=
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Supabase
# The backend also accepts API_URL, anon_public, publishable_key, service_role, and secret_key aliases.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# Ollama embeddings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
EMBEDDING_DIM=768

# Optional alias style if you prefer separate values:
# GROQ_API_KEY1=
# GROQ_API_KEY2=
# API_URL=https://your-project.supabase.co/rest/v1/
# anon_public=
# service_role=
